From 9a3053b7970c0284dcfbd851feae41bdfc4a7690 Mon Sep 17 00:00:00 2001
From: Stefan Mayer <stevijo.mayer@googlemail.com>
Date: Fri, 13 Mar 2026 16:53:19 +0100
Subject: [PATCH] add chacha20 poly1305 support

---
 plugins/linux-cp/lcp_ipsec.c | 10 ++++++++++
 1 file changed, 10 insertions(+)

diff --git a/plugins/linux-cp/lcp_ipsec.c b/plugins/linux-cp/lcp_ipsec.c
index 786844822..c4c83d2b9 100644
--- a/plugins/linux-cp/lcp_ipsec.c
+++ b/plugins/linux-cp/lcp_ipsec.c
@@ -321,6 +321,10 @@ get_crypto_algo (char *alg, int len, ipsec_crypto_alg_t *val)
 
   else if (!strcmp (alg, "cbc(des3-cede)"))
     *val = IPSEC_CRYPTO_ALG_3DES_CBC;
+  
+  else if (!strcmp (alg, "rfc7539esp(chacha20,poly1305)"))
+    * val = IPSEC_CRYPTO_ALG_CHACHA20_POLY1305;
+
   else
     *val = IPSEC_CRYPTO_N_ALG;
 }
@@ -1156,6 +1160,12 @@ nl_xfrm_sa_add (struct xfrmnl_sa *sa)
    */
   if (IPSEC_CRYPTO_ALG_IS_GCM (crypto_alg))
     lcp_xfrm_extract_gcm_key_and_salt (crypto_alg, key, &ck, &salt);
+  else if (crypto_alg == IPSEC_CRYPTO_ALG_CHACHA20_POLY1305)
+    {
+        ck.len = 32
+        clib_memcpy_fast (ck.data, (u8 *) key, ck.len);
+        clib_memcpy_fast (&salt, ((u8 *) key) + ck.len, GCM_SALT_SIZE);
+    }
   else
     {
       /* Non-GCM: use key as-is */
